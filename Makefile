# ============================================================================
# RISC-V 内核 Makefile
# ============================================================================
# 这个文件告诉电脑如何编译你的内核代码
# 就像一本菜谱，告诉厨师：要用什么锅、什么火、先放什么后放什么
# ============================================================================

# ----------------------------------------------------------------------------
# 编译器设置
# ----------------------------------------------------------------------------

# CC = C Compiler（C编译器）
# riscv64-unknown-elf-gcc：专门为RISC-V 64位架构编译裸机程序（没有操作系统的程序）的编译器
# 它运行在你的x86电脑上，但生成的是RISC-V CPU能理解的机器码（交叉编译）
CC = riscv64-elf-gcc

# CFLAGS = C Compiler Flags（C编译器标志）
# 这些是给编译器的额外指令，控制它怎么编译代码
CFLAGS = -nostdlib -nostartfiles -ffreestanding -Wall -g -Idrivers

# 逐个解释每个标志：
# -nostdlib        : 不使用标准C库（因为内核里没有printf、malloc这些函数，你要自己写）
# -nostartfiles    : 不使用标准的启动文件（内核的入口是_start，不是main）
# -ffreestanding   : 编译为独立环境（不依赖操作系统的代码，比如内核、引导程序）
# -Wall            : 打开所有警告（帮助你发现代码中的潜在问题）
# -g               : 生成调试信息（方便用GDB调试内核，可以看到变量名和行号）

# LDFLAGS = Linker Flags（链接器标志）
# 链接器负责把多个编译好的文件（.o文件）合并成一个可执行文件
# -T kernel.ld     : 使用 kernel.ld 作为链接脚本
#                    链接脚本告诉链接器：代码放内存的哪个地址？栈放哪里？入口点是哪个符号？
LDFLAGS = -T kernel.ld

# ----------------------------------------------------------------------------
# 源文件列表
# ----------------------------------------------------------------------------

# OBJS = OBJectS（目标文件列表）
# 所有需要编译的源文件对应的 .o 文件
# boot/start.S 编译后变成 boot/start.o
# kernel/main.c 编译后变成 kernel/main.o
# 链接器会把这两个 .o 文件合并成最终的内核镜像
OBJS = boot/start.o kernel/main.o drivers/uart.o

# ----------------------------------------------------------------------------
# 默认目标（当你直接输入 `make` 时执行的目标）
# ----------------------------------------------------------------------------

# all 是第一个目标，所以 `make` 命令会执行它
# all 依赖于 mykernel.elf，所以会先构建 mykernel.elf
all: mykernel.elf

# ----------------------------------------------------------------------------
# 链接目标：把 .o 文件合并成最终的内核镜像
# ----------------------------------------------------------------------------

# $@ : 目标文件名（这里是 mykernel.elf）
# $^ : 所有依赖文件（这里是 $(OBJS) 里的所有文件）
# 这条命令的意思是：用编译器（CC）加上链接标志（LDFLAGS），
# 把所有的 .o 文件（$^）链接成 mykernel.elf（$@）
mykernel.elf: $(OBJS)
	$(CC) $(CFLAGS) $(LDFLAGS) -o $@ $^

# ----------------------------------------------------------------------------
# 编译规则：把 .c 文件编译成 .o 文件
# ----------------------------------------------------------------------------

# %.o: %.c 是一个模式规则
# 意思是：任何 .o 文件都可以从同名的 .c 文件编译得到
# 例如：kernel/main.o 会由 kernel/main.c 编译而来
# -c 标志：只编译，不链接（生成 .o 文件）
%.o: %.c
	$(CC) $(CFLAGS) -c -o $@ $^

# ----------------------------------------------------------------------------
# 编译规则：把 .S 文件（汇编代码）编译成 .o 文件
# ----------------------------------------------------------------------------

# .S 文件是汇编语言源文件（大写S表示需要预处理，支持宏、include等）
# 例如：boot/start.S 会由这个规则编译
# 注意：小写 .s 文件是不需要预处理的纯汇编，规则类似
%.o: %.S
	$(CC) $(CFLAGS) -c -o $@ $^

# ----------------------------------------------------------------------------
# 运行目标：在QEMU模拟器中启动内核
# ----------------------------------------------------------------------------

# 输入 `make run` 会执行这个目标
# 它依赖于 mykernel.elf，所以会先确保内核已经编译好
# $< 是第一个依赖文件（这里是 mykernel.elf）
# qemu-system-riscv64 : RISC-V 64位模拟器
# -machine virt      : 使用通用的虚拟机器（virt机器）
# -kernel $<         : 使用我们的内核文件作为内核
# -nographic         : 不使用图形窗口，所有输出在终端显示（调试更方便）
run: mykernel.elf
	qemu-system-riscv64 -machine virt -kernel $< -nographic

# ----------------------------------------------------------------------------
# 清理目标：删除所有编译生成的文件
# ----------------------------------------------------------------------------

# 输入 `make clean` 会执行这个目标
# rm -f : 强制删除文件（不询问）
# 删除所有 .o 文件（OBJS）和最终的内核镜像（mykernel.elf）
# 让你能从头开始重新编译（解决编译缓存导致的问题）
clean:
	rm -f $(OBJS) mykernel.elf

# ============================================================================
# 使用示例：
# ============================================================================
# $ make          # 编译内核
# $ make run      # 在QEMU中运行内核
# $ make clean    # 清理编译产物
# $ make clean all # 清理后重新编译
# ============================================================================
